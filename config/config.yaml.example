esp_idf_path: "C:/Espressif/esp-idf"
project_path: "."
log_level: "INFO"
log_dir: "logs"

plugins:
  idf:
    enabled: true
    esp_idf_path: "C:/Espressif/esp-idf"
    project_path: "."

  serial:
    enabled: true
    default_baudrate: 115200

  build:
    enabled: true

  monitor:
    enabled: true
    max_data_size: 1000

  logger:
    enabled: true
    log_dir: "logs"
